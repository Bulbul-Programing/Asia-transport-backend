model TR {
    id               String     @id @default(uuid())
    TRID             String      @unique()
    shopId           String
    shopName         String
    quantity         Int
    paymentStatus    Boolean
    taka             Float
    bookingDate      DateTime
    isOfficeDelivery Boolean
    note             String?
    createdAt        DateTime   @default(now())
    updateAt         DateTime   @updatedAt
    shop             Shop       @relation(fields: [shopId], references: [id])
    partyLes         partyLes[]
}
